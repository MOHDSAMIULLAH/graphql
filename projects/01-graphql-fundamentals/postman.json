{
  "info": {
    "_postman_id": "graphql-fundamentals",
    "name": "GraphQL Fundamentals",
    "description": "Collection for testing GraphQL Fundamentals project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Users",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\n  users {\n    id\n    name\n    email\n    age\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:4000/graphql",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["graphql"]
        }
      }
    },
    {
      "name": "Get User with Posts",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\n  user(id: \"1\") {\n    id\n    name\n    email\n    age\n    posts {\n      id\n      title\n      content\n    }\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:4000/graphql",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["graphql"]
        }
      }
    },
    {
      "name": "Get Post with Author",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\n  post(id: \"1\") {\n    id\n    title\n    content\n    author {\n      id\n      name\n      email\n    }\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:4000/graphql",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["graphql"]
        }
      }
    },
    {
      "name": "Get All Posts with Authors",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\n  posts {\n    id\n    title\n    content\n    author {\n      id\n      name\n      email\n    }\n  }\n}"
          }
        },
        "url": {
          "raw": "http://localhost:4000/graphql",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["graphql"]
        }
      }
    }
  ]
}
